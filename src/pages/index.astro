---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const posts = allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout title="蔡霖東">
  <div class="page">
    <section class="bio">
      <p class="name">蔡霖東</p>
    </section>

    <section class="posts">
      {posts.map(post => {
        const date = post.data.date.toLocaleDateString('zh-TW', {
          year: 'numeric',
          month: 'long',
          day: 'numeric',
        });
        return (
          <div class="post-entry">
            <time class="entry-date">{date}</time>
            <a href={`/posts/${post.slug}`} class="entry-title">{post.data.title}</a>
          </div>
        );
      })}
    </section>
  </div>
</BaseLayout>

<style>
  .page {
    padding: 4rem 0 1.5rem 0;
  }

  .divider {
    border: none;
    background: var(--color-border-subtle);
    height: 1px;
    margin: 2.5em 0;
  }

  /* ─── Bio ────────────────────────────────────────────────── */

  .bio {
    padding-bottom: 0;
  }

.name {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 1.5rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-title-ink);
    margin: 0 0 2rem 0;
  }

  .bio-text {
    font-family: var(--font-serif);
    font-size: 1rem;
    line-height: 1.8;
    color: var(--color-text);
    margin: 0;
  }

  .bio-text a {
    color: inherit;
    text-decoration: underline;
    text-decoration-color: var(--color-border);
    text-underline-offset: 3px;
    transition: text-decoration-color 150ms ease;
  }

  .bio-text a:hover {
    text-decoration-color: var(--color-accent);
  }

  /* ─── Post list ──────────────────────────────────────────── */

  .posts {
    display: flex;
    flex-direction: column;
    gap: 2.25em;
  }

  .post-entry {
    display: flex;
    flex-direction: column;
    gap: 0.2em;
  }

  .entry-date {
    font-family: var(--font-body);
    font-size: 0.78rem;
    color: var(--color-text-muted);
  }

  .entry-title {
    font-family: var(--font-serif);
    font-size: 1.2rem;
    font-weight: 400;
    color: var(--color-title-ink);
    text-decoration: none;
    transition: color 150ms ease;
  }

  .entry-title:hover {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
</style>
