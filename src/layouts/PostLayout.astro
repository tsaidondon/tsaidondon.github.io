---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  date: Date;
}

const { title, date } = Astro.props;

const formattedDate = date.toLocaleDateString('zh-TW', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={title}>
  <article>
    <header class="post-header">
      <a href="/" class="back">蔡霖東</a>
      <h1 class="post-title">{title}</h1>
      <time class="post-date" datetime={date.toISOString()}>{formattedDate}</time>
    </header>
    <div class="post-content">
      <slot />
    </div>
  </article>
</BaseLayout>

<style>
  article {
    padding-top: 0.5rem;
  }

  .post-header {
    margin-bottom: 2rem;
  }

  .back {
    display: block;
    font-family: var(--font-display);
    font-size: 0.85rem;
    font-variant: small-caps;
    letter-spacing: 0.2em;
    color: #888;
    text-decoration: none;
    margin-bottom: 1.5rem;
    transition: color 150ms ease;
  }

  .back:hover {
    color: var(--color-accent);
  }

  .post-date {
    display: block;
    font-family: var(--font-body);
    font-size: 0.78rem;
    color: var(--color-text-muted);
    margin-top: 0.4rem;
  }

  .post-title {
    font-family: var(--font-serif);
    font-size: 1.8rem;
    font-weight: 500;
    color: var(--color-title-ink);
    line-height: 1.3;
    margin: 0;
  }

  /* ─── Post body ──────────────────────────────────────────── */

  .post-content {
    font-size: 1rem;
    line-height: 1.65;
  }

  .post-content :global(p) {
    margin-bottom: 1.4em;
  }

  .post-content :global(h1),
  .post-content :global(h2),
  .post-content :global(h3) {
    font-family: var(--font-serif);
    font-weight: 500;
    color: var(--color-title-ink);
    line-height: 1.4;
    margin-top: 2em;
    margin-bottom: 0.5em;
  }

  .post-content :global(h2) { font-size: 1.2rem; }
  .post-content :global(h3) { font-size: 1.05rem; }

  .post-content :global(em) {
    color: var(--color-text-muted);
  }

  .post-content :global(hr) {
    border: none;
    background: var(--color-border-subtle);
    height: 1px;
    margin: 2.5em 0;
  }

  .post-content :global(blockquote) {
    border-left: 2px solid var(--color-border);
    padding-left: 1.25em;
    margin-left: 0;
    margin-right: 0;
    color: var(--color-text-muted);
  }

  .post-content :global(a) {
    color: var(--color-accent);
    text-decoration: none;
    transition: color 150ms ease;
  }

  .post-content :global(a:hover) {
    color: var(--color-accent-hover);
    text-decoration: underline;
  }
</style>
