---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { title = '蔡霖東', description = '' } = Astro.props;
const fullTitle = title === '蔡霖東' ? title : `${title} — 蔡霖東`;
---

<!doctype html>
<html lang="zh-TW">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    {description && <meta name="description" content={description} />}
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <title>{fullTitle}</title>
  </head>
  <body>
    <main>
      <slot />
    </main>

    <footer>
      <div class="footer-inner">
        <span>© {new Date().getFullYear()} 蔡霖東</span>
      </div>
    </footer>
  </body>
</html>

<style>
  footer {
    margin-top: auto;
    padding-top: 1.5rem;
  }

  .footer-inner {
    max-width: 720px;
    margin: 0 auto;
    padding: 20px 24px;
    text-align: center;
  }

  .footer-inner span {
    font-size: 0.75rem;
    color: var(--color-text-muted);
  }
</style>
